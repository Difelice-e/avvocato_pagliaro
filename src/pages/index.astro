---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import CTASection from '../components/CTASection.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LegalService',
      '@id': 'https://www.avvocatopagliaro.it/#organization',
      name: 'Studio Legale Pagliaro',
      url: 'https://www.avvocatopagliaro.it',
      logo: 'https://www.avvocatopagliaro.it/imgs/ema_pagliaro.jpg',
      description: 'Studio Legale Pagliaro specializzato in diritto del lavoro, previdenza sociale e pubblico impiego.',
      email: 'info@avvocatopagliaro.it',
      telephone: '+390871000000',
      areaServed: 'IT',
      address: [
        { '@type': 'PostalAddress', addressLocality: 'Chieti', addressRegion: 'CH', addressCountry: 'IT' },
        { '@type': 'PostalAddress', addressLocality: 'Roma', addressRegion: 'RM', addressCountry: 'IT' },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://www.avvocatopagliaro.it/#website',
      url: 'https://www.avvocatopagliaro.it',
      name: 'Studio Legale Pagliaro',
      publisher: { '@id': 'https://www.avvocatopagliaro.it/#organization' },
    },
  ],
});
---

<Layout
  title="Studio Legale Pagliaro — Diritto del Lavoro, Chieti e Roma"
  description="Studio Legale Pagliaro specializzato in diritto del lavoro, previdenza sociale e pubblico impiego. Sedi a Chieti e Roma."
  canonical="https://www.avvocatopagliaro.it/"
  currentPage="home"
  jsonLd={jsonLd}
>
  <main>
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center pt-24 overflow-hidden bg-surface">
      <div class="max-w-7xl mx-auto px-8 w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7 z-10">
          <PageHero eyebrow="Diritto del lavoro · Chieti e Roma">
            Il lavoro <span class="italic">è un diritto</span>.<br />Difenderlo, una <span class="italic">professione</span>.
          </PageHero>
          <p class="hero-anim-3 text-on-surface-variant text-xl max-w-xl mb-12 leading-relaxed">
            Licenziamenti illegittimi, demansionamento, mobbing, previdenza. Tutela rigorosa del lavoratore in via stragiudiziale e in ogni grado di giudizio.
          </p>
          <div class="hero-anim-4 flex flex-col sm:flex-row gap-6">
            <a
              href={`${base}/contatti`}
              class="group inline-flex items-center justify-center gap-3 bg-primary text-on-primary px-8 py-5 rounded-sm font-label text-sm uppercase tracking-widest shadow-xl shadow-primary/10 hover:bg-primary/85 active:scale-[0.97] transition-all duration-200"
            >
              Richiedi una Consulenza
              <span class="material-symbols-outlined text-base cta-arrow">arrow_forward</span>
            </a>
            <a
              href={`${base}/competenze`}
              class="group flex items-center gap-3 text-primary font-label text-sm uppercase tracking-widest border-b border-transparent hover:border-tertiary-fixed-dim transition-all duration-200 py-5"
            >
              Scopri le Competenze
              <span class="material-symbols-outlined text-tertiary-fixed-dim cta-arrow">arrow_forward</span>
            </a>
          </div>
        </div>
        <div class="hero-img-anim lg:col-span-5 relative h-[600px] lg:h-[800px]">
          <div class="absolute inset-0 bg-primary-container/5 rounded-sm overflow-hidden transform translate-x-4 translate-y-4"></div>
          <img
            alt="Avv. Emanuele Pagliaro — Studio Legale Pagliaro"
            class="absolute inset-0 w-full h-full object-cover rounded-sm grayscale"
            src={`${base}/imgs/ema_pagliaro.jpg`}
          />
          <div class="absolute -bottom-8 -left-8 bg-surface-container-lowest p-8 shadow-2xl max-w-xs border-t-2 border-primary rounded-sm hidden lg:block">
            <p class="font-serif italic text-primary text-xl">"La giustizia non è un privilegio, ma un diritto di ogni lavoratore."</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Aree di Specializzazione -->
    <section class="py-32 bg-surface-container-low">
      <div class="max-w-7xl mx-auto px-8">
        <SectionTitle eyebrow="Cosa Facciamo" description="Consulenza specializzata in diritto del lavoro, previdenza e pubblico impiego: dalla controversia sindacale al ricorso previdenziale.">
          Aree di Specializzazione
        </SectionTitle>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="reveal reveal-delay-1 bento-card md:col-span-2 group relative overflow-hidden bg-surface-container-lowest p-12 flex flex-col cursor-default">
            <div>
              <h3 class="font-headline text-4xl text-primary mb-4">Diritto del Lavoro</h3>
              <p class="text-on-surface-variant max-w-lg">
                Tutela del lavoratore in ogni fase del rapporto di lavoro: licenziamenti, demansionamento, mobbing, discriminazioni e risarcimenti.
              </p>
            </div>
          </div>
          <div class="reveal reveal-delay-2 bento-card group relative overflow-hidden bg-primary text-on-primary p-12 flex flex-col cursor-default">
            <div>
              <h3 class="font-headline text-3xl mb-4">Previdenza Sociale</h3>
              <p class="text-on-primary-container text-sm leading-relaxed">
                Pensioni, invalidità, contributi figurativi e ricorsi INPS. Difendiamo i vostri diritti previdenziali in ogni sede.
              </p>
            </div>
          </div>
          <div class="reveal reveal-delay-2 bento-card group relative overflow-hidden bg-surface-container-highest p-12 flex flex-col cursor-default">
            <div class="relative z-10">
              <h3 class="font-headline text-3xl text-primary mb-4">Pubblico Impiego</h3>
              <p class="text-on-surface-variant text-sm">Controversie con enti pubblici, concorsi, progressioni di carriera e disciplinari.</p>
            </div>
          </div>
          <div class="reveal reveal-delay-3 bento-card md:col-span-2 group relative overflow-hidden bg-surface-container-lowest p-12 flex items-center cursor-default">
            <div class="max-w-md">
              <h3 class="font-headline text-3xl text-primary mb-4">Diritto Sindacale &amp; Infortunistica</h3>
              <p class="text-on-surface-variant mb-8">Assistenza nelle vertenze sindacali, nei procedimenti INAIL e nei risarcimenti per infortuni sul lavoro.</p>
              <a
                href={`${base}/competenze`}
                class="group/link inline-flex items-center gap-2 text-primary font-label text-xs uppercase tracking-widest border-b border-primary pb-1 hover:gap-3 transition-all duration-200"
              >
                Approfondisci
                <span class="material-symbols-outlined text-sm cta-arrow">arrow_forward</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Perché Sceglierci — VALORI SEGNAPOSTO: 48h SLA, 100% materia esclusiva, 200+ vertenze. Sostituire con dati reali. -->
    <section class="py-32 bg-surface-container-low">
      <div class="max-w-7xl mx-auto px-8">
        <SectionTitle eyebrow="Lo Studio in cifre">
          Perché lo Studio Pagliaro.
        </SectionTitle>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
          <div class="reveal reveal-delay-1">
            <p class="font-headline font-extrabold text-7xl text-primary leading-none mb-4">48h</p>
            <p class="font-label text-xs uppercase tracking-[0.25em] text-on-surface-variant mb-6">Tempo di risposta</p>
            <p class="text-on-surface-variant leading-relaxed">
              Ogni richiesta riceve un primo riscontro entro due giorni lavorativi. Nel diritto del lavoro i termini decadenziali contano: lo studio risponde nei tempi del cliente, non nei propri.
            </p>
          </div>
          <div class="reveal reveal-delay-2">
            <p class="font-headline font-extrabold text-7xl text-primary leading-none mb-4">100%</p>
            <p class="font-label text-xs uppercase tracking-[0.25em] text-on-surface-variant mb-6">Materia esclusiva</p>
            <p class="text-on-surface-variant leading-relaxed">
              Solo diritto del lavoro, previdenza sociale e pubblico impiego. Nessuna pratica fuori specializzazione: ogni causa beneficia di vent&rsquo;anni di esperienza concentrata.
            </p>
          </div>
          <div class="reveal reveal-delay-3">
            <p class="font-headline font-extrabold text-7xl text-primary leading-none mb-4">200+</p>
            <p class="font-label text-xs uppercase tracking-[0.25em] text-on-surface-variant mb-6">Vertenze trattate</p>
            <p class="text-on-surface-variant leading-relaxed">
              Casistica costruita su licenziamenti, demansionamenti, mobbing, ricorsi INPS e contenzioso pubblico impiego. Ogni precedente trattato è un riferimento per i casi successivi.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <CTASection
      title="Pronti a tutelare i vostri diritti?"
      description="Contattateci per una prima consulenza. Operiamo in presenza a Chieti e Roma, o a distanza in tutta Italia."
      primaryHref={`${base}/contatti`}
      primaryLabel="Contattaci Ora"
      secondaryHref="tel:+390871000000"
      secondaryLabel="Chiamaci"
      secondaryIsPhone={true}
    />
  </main>
</Layout>

<script>
  // Stat counter animation (homepage only)
  (function () {
    const statEls = document.querySelectorAll('.stat-num[data-target]');
    if (!statEls.length) return;
    const counterObserver = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0', 10);
        const suffix = el.dataset.suffix || '';
        const duration = 1200;
        const start = performance.now();
        function tick(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        counterObserver.unobserve(el);
      });
    }, { threshold: 0.5 });
    statEls.forEach(function (el) { counterObserver.observe(el); });
  })();
</script>
