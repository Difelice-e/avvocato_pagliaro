---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LegalService',
      '@id': 'https://www.avvocatopagliaro.it/#organization',
      name: 'Studio Legale Pagliaro',
      url: 'https://www.avvocatopagliaro.it',
      logo: 'https://www.avvocatopagliaro.it/imgs/ema_pagliaro.jpg',
      description: 'Studio Legale Pagliaro specializzato in diritto del lavoro, previdenza sociale e pubblico impiego.',
      email: 'info@avvocatopagliaro.it',
      telephone: '+390871000000',
      areaServed: 'IT',
      address: [
        { '@type': 'PostalAddress', addressLocality: 'Chieti', addressRegion: 'CH', addressCountry: 'IT' },
        { '@type': 'PostalAddress', addressLocality: 'Roma', addressRegion: 'RM', addressCountry: 'IT' },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://www.avvocatopagliaro.it/#website',
      url: 'https://www.avvocatopagliaro.it',
      name: 'Studio Legale Pagliaro',
      publisher: { '@id': 'https://www.avvocatopagliaro.it/#organization' },
    },
  ],
});
---

<Layout
  title="Studio Legale Pagliaro — Diritto del Lavoro, Chieti e Roma"
  description="Studio Legale Pagliaro specializzato in diritto del lavoro, previdenza sociale e pubblico impiego. Sedi a Chieti e Roma."
  canonical="https://www.avvocatopagliaro.it/"
  currentPage="home"
  jsonLd={jsonLd}
>
  <main>
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center pt-24 overflow-hidden bg-surface">
      <div class="max-w-7xl mx-auto px-8 w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7 z-10">
          <span class="hero-anim-1 text-tertiary-fixed-dim font-label text-sm uppercase tracking-[0.3em] mb-6 block">Diritto del Lavoro &amp; Previdenza Sociale</span>
          <h1 class="hero-anim-2 font-serif text-primary leading-[1.1] tracking-tight mb-8 text-6xl lg:text-8xl">
            Il tuo diritto è <br /> <span class="italic text-tertiary-fixed-dim">la mia professione.</span>
          </h1>
          <p class="hero-anim-3 text-on-surface-variant text-xl max-w-xl mb-12 leading-relaxed">
            Un approccio umano e preciso alla tutela dei lavoratori. Proteggiamo i vostri diritti con rigore giuridico e attenzione alle persone, a Chieti e a Roma.
          </p>
          <div class="hero-anim-4 flex flex-col sm:flex-row gap-6">
            <a
              href={`${base}/contatti`}
              class="group inline-flex items-center justify-center gap-3 bg-primary text-on-primary px-8 py-5 rounded-sm font-label text-sm uppercase tracking-widest shadow-xl shadow-primary/10 hover:bg-primary/85 active:scale-[0.97] transition-all duration-200"
            >
              Richiedi una Consulenza
              <span class="material-symbols-outlined text-base cta-arrow">arrow_forward</span>
            </a>
            <a
              href={`${base}/competenze`}
              class="group flex items-center gap-3 text-primary font-label text-sm uppercase tracking-widest border-b border-transparent hover:border-tertiary-fixed-dim transition-all duration-200 py-5"
            >
              Scopri le Competenze
              <span class="material-symbols-outlined text-tertiary-fixed-dim cta-arrow">arrow_forward</span>
            </a>
          </div>
        </div>
        <div class="hero-img-anim lg:col-span-5 relative h-[600px] lg:h-[800px]">
          <div class="absolute inset-0 bg-primary-container/5 rounded-sm overflow-hidden transform translate-x-4 translate-y-4"></div>
          <img
            alt="Avv. Emanuele Pagliaro — Studio Legale Pagliaro"
            class="absolute inset-0 w-full h-full object-cover rounded-sm grayscale"
            src={`${base}/imgs/ema_pagliaro.jpg`}
          />
          <div class="absolute -bottom-8 -left-8 bg-surface-container-lowest p-8 shadow-2xl max-w-xs border-l-4 border-tertiary-fixed-dim rounded-sm hidden lg:block">
            <p class="font-serif italic text-primary text-xl">"La giustizia non è un privilegio, ma un diritto di ogni lavoratore."</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Aree di Specializzazione -->
    <section class="py-32 bg-surface-container-low">
      <div class="max-w-7xl mx-auto px-8">
        <div class="reveal flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
          <div class="max-w-2xl">
            <h2 class="font-serif text-5xl text-primary mb-6">Aree di Specializzazione</h2>
            <div class="h-1 w-24 bg-tertiary-fixed-dim"></div>
          </div>
          <p class="text-on-surface-variant max-w-md font-body leading-relaxed">
            Consulenza specializzata in diritto del lavoro, previdenza e pubblico impiego: dalla controversia sindacale al ricorso previdenziale.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="reveal reveal-delay-1 bento-card md:col-span-2 group relative overflow-hidden bg-surface-container-lowest p-12 h-96 flex flex-col justify-between cursor-default">
            <span class="material-symbols-outlined text-4xl text-tertiary-fixed-dim">work</span>
            <div>
              <h3 class="font-serif text-4xl text-primary mb-4">Diritto del Lavoro</h3>
              <p class="text-on-surface-variant max-w-lg opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                Tutela del lavoratore in ogni fase del rapporto di lavoro: licenziamenti, demansionamento, mobbing, discriminazioni e risarcimenti.
              </p>
            </div>
            <div class="absolute top-0 right-0 p-8 text-on-surface-variant/10 text-9xl font-serif">01</div>
          </div>
          <div class="reveal reveal-delay-2 bento-card group relative overflow-hidden bg-primary text-on-primary p-12 h-96 flex flex-col justify-between cursor-default">
            <span class="material-symbols-outlined text-4xl text-tertiary-fixed-dim">account_balance</span>
            <div>
              <h3 class="font-serif text-3xl mb-4">Previdenza Sociale</h3>
              <p class="text-on-primary-container text-sm leading-relaxed">
                Pensioni, invalidità, contributi figurativi e ricorsi INPS. Difendiamo i vostri diritti previdenziali in ogni sede.
              </p>
            </div>
          </div>
          <div class="reveal reveal-delay-2 bento-card group relative overflow-hidden bg-surface-container-highest p-12 h-96 flex flex-col justify-between cursor-default">
            <span class="material-symbols-outlined text-4xl text-primary relative z-10">domain</span>
            <div class="relative z-10">
              <h3 class="font-serif text-3xl text-primary mb-4">Pubblico Impiego</h3>
              <p class="text-on-surface-variant text-sm">Controversie con enti pubblici, concorsi, progressioni di carriera e disciplinari.</p>
            </div>
          </div>
          <div class="reveal reveal-delay-3 bento-card md:col-span-2 group relative overflow-hidden bg-surface-container-lowest p-12 h-96 flex items-center justify-between border-l-4 border-tertiary-fixed-dim cursor-default">
            <div class="max-w-md">
              <h3 class="font-serif text-3xl text-primary mb-4">Diritto Sindacale &amp; Infortunistica</h3>
              <p class="text-on-surface-variant mb-8">Assistenza nelle vertenze sindacali, nei procedimenti INAIL e nei risarcimenti per infortuni sul lavoro.</p>
              <a
                href={`${base}/competenze`}
                class="group/link inline-flex items-center gap-2 text-primary font-label text-xs uppercase tracking-widest border-b border-primary pb-1 hover:gap-3 transition-all duration-200"
              >
                Approfondisci
                <span class="material-symbols-outlined text-sm cta-arrow">arrow_forward</span>
              </a>
            </div>
            <span class="material-symbols-outlined text-8xl text-surface-container-high">gavel</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Chi Siamo -->
    <section class="py-32 bg-surface">
      <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
        <div class="reveal relative">
          <div class="aspect-[4/5] bg-surface-container overflow-hidden">
            <img
              alt="Avv. G. Pagliaro — Studio Legale Pagliaro"
              class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
              src={`${base}/imgs/gia_pagliaro.jpg`}
            />
          </div>
          <div class="absolute -bottom-8 -right-8 bg-primary-container p-12 text-on-primary max-w-xs shadow-2xl hidden md:block">
            <h4 class="font-serif text-2xl mb-2">Avv. Emanuele Pagliaro</h4>
            <p class="text-tertiary-fixed-dim text-sm uppercase tracking-widest mb-4">Avvocato Titolare</p>
            <p class="text-on-primary-container text-xs leading-relaxed italic">
              "Il diritto del lavoro tutela la dignità delle persone. Questo è il mio impegno quotidiano."
            </p>
          </div>
        </div>
        <div class="reveal reveal-delay-2">
          <span class="text-tertiary-fixed-dim font-label text-sm uppercase tracking-[0.3em] mb-6 block">La Nostra Filosofia</span>
          <h2 class="font-serif text-5xl text-primary mb-8 leading-tight">L&rsquo;arte di difendere chi lavora.</h2>
          <div class="space-y-6 text-on-surface-variant text-lg leading-relaxed">
            <p>
              Lo Studio Legale Pagliaro nasce dalla profonda convinzione che ogni lavoratore meriti una difesa competente, accessibile e dedicata. Non siamo solo consulenti: siamo al fianco dei nostri clienti in ogni fase della controversia.
            </p>
            <p>
              Ogni caso viene trattato con la cura dovuta alla persona, analizzando ogni aspetto per costruire una strategia efficace e trasparente, sia in sede giudiziale che stragiudiziale.
            </p>
          </div>
          <div class="mt-12 grid grid-cols-2 gap-8 border-t border-outline-variant/15 pt-12">
            <div>
              <p class="text-4xl font-serif text-primary">
                <span class="stat-num" data-target="20" data-suffix="+">20+</span>
              </p>
              <p class="text-xs uppercase tracking-widest text-on-surface-variant mt-1">Anni di Esperienza</p>
            </div>
            <div>
              <p class="text-4xl font-serif text-primary">2 Sedi</p>
              <p class="text-xs uppercase tracking-widest text-on-surface-variant mt-1">Chieti &amp; Roma</p>
            </div>
          </div>
          <div class="mt-10">
            <a
              href={`${base}/profilo`}
              class="group inline-flex items-center gap-3 border border-primary text-primary px-8 py-4 rounded-sm font-label text-sm uppercase tracking-widest hover:bg-primary hover:text-on-primary active:scale-[0.97] transition-all duration-200"
            >
              Scopri il Profilo
              <span class="material-symbols-outlined text-base cta-arrow">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Perché Sceglierci -->
    <section class="py-32 bg-primary relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
        <img
          src="https://images.unsplash.com/photo-1589994965851-a8f479c573a9?w=1400&auto=format&fit=crop&q=80"
          alt=""
          class="w-full h-full object-cover opacity-[0.05] mix-blend-luminosity"
        />
      </div>
      <div class="max-w-7xl mx-auto px-8 relative z-10">
        <div class="reveal text-center mb-24">
          <h2 class="font-serif text-4xl text-on-primary">Perché Scegliere lo Studio Pagliaro</h2>
          <div class="h-px w-16 bg-tertiary-fixed-dim mx-auto mt-6"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
          <div class="reveal reveal-delay-1 text-center group cursor-default">
            <div class="w-20 h-20 mx-auto bg-surface-container-highest/10 flex items-center justify-center mb-8 group-hover:bg-tertiary-fixed-dim transition-colors duration-300">
              <span class="material-symbols-outlined text-tertiary-fixed-dim group-hover:text-primary transition-colors duration-300">speed</span>
            </div>
            <h3 class="font-serif text-2xl text-on-primary mb-4">Tempestività</h3>
            <p class="text-on-primary-container text-sm leading-relaxed px-4">
              Prima consultazione nei tempi del cliente. Risposte rapide perché nel diritto del lavoro i termini contano.
            </p>
          </div>
          <div class="reveal reveal-delay-2 text-center group cursor-default">
            <div class="w-20 h-20 mx-auto bg-surface-container-highest/10 flex items-center justify-center mb-8 group-hover:bg-tertiary-fixed-dim transition-colors duration-300">
              <span class="material-symbols-outlined text-tertiary-fixed-dim group-hover:text-primary transition-colors duration-300">shield</span>
            </div>
            <h3 class="font-serif text-2xl text-on-primary mb-4">Specializzazione</h3>
            <p class="text-on-primary-container text-sm leading-relaxed px-4">
              Focus esclusivo su diritto del lavoro e previdenza: una competenza profonda, non generica.
            </p>
          </div>
          <div class="reveal reveal-delay-3 text-center group cursor-default">
            <div class="w-20 h-20 mx-auto bg-surface-container-highest/10 flex items-center justify-center mb-8 group-hover:bg-tertiary-fixed-dim transition-colors duration-300">
              <span class="material-symbols-outlined text-tertiary-fixed-dim group-hover:text-primary transition-colors duration-300">people</span>
            </div>
            <h3 class="font-serif text-2xl text-on-primary mb-4">Approccio Umano</h3>
            <p class="text-on-primary-container text-sm leading-relaxed px-4">
              Ogni cliente è una persona, non un fascicolo. Ascoltiamo prima di agire.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-32">
      <div class="max-w-5xl mx-auto px-8">
        <div class="reveal bg-surface-container-highest p-16 md:p-24 text-center relative overflow-hidden border-l-4 border-tertiary-fixed-dim">
          <h2 class="font-serif text-5xl text-primary mb-8 leading-tight">Pronti a tutelare i vostri diritti?</h2>
          <p class="text-on-surface-variant text-xl mb-12 max-w-2xl mx-auto leading-relaxed">
            Contattaci per una prima consulenza. Operiamo in presenza a Chieti e Roma, o a distanza in tutta Italia.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href={`${base}/contatti`}
              class="group inline-flex items-center justify-center gap-3 bg-primary text-on-primary px-12 py-5 rounded-sm font-label text-sm uppercase tracking-widest hover:bg-primary/85 active:scale-[0.97] transition-all duration-200"
            >
              Contattaci Ora
              <span class="material-symbols-outlined text-base cta-arrow">arrow_forward</span>
            </a>
            <a
              href="tel:+390871000000"
              class="group inline-flex items-center justify-center gap-3 border border-primary text-primary px-10 py-5 rounded-sm font-label text-sm uppercase tracking-widest hover:bg-primary hover:text-on-primary active:scale-[0.97] transition-all duration-200"
            >
              <span class="material-symbols-outlined text-base">phone</span>
              Chiamaci
            </a>
          </div>
          <div class="absolute top-0 right-0 p-12 opacity-5 pointer-events-none select-none">
            <span class="material-symbols-outlined text-[200px]">balance</span>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  // Stat counter animation (homepage only)
  (function () {
    const statEls = document.querySelectorAll('.stat-num[data-target]');
    if (!statEls.length) return;
    const counterObserver = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0', 10);
        const suffix = el.dataset.suffix || '';
        const duration = 1200;
        const start = performance.now();
        function tick(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        counterObserver.unobserve(el);
      });
    }, { threshold: 0.5 });
    statEls.forEach(function (el) { counterObserver.observe(el); });
  })();
</script>
