---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.avvocatopagliaro.it/' },
    { '@type': 'ListItem', position: 2, name: 'Contatti', item: 'https://www.avvocatopagliaro.it/contatti' },
  ],
});
---

<Layout
  title="Contatti | Studio Legale Pagliaro — Chieti e Roma"
  description="Contatta lo Studio Legale Pagliaro. Sedi a Chieti (Corso Marrucino) e Roma (Via del Corso). Consulenze in presenza, per telefono o in videochiamata."
  canonical="https://www.avvocatopagliaro.it/contatti"
  currentPage="contatti"
  jsonLd={jsonLd}
>
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <header class="max-w-7xl mx-auto px-8 mb-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
        <div class="lg:col-span-8">
          <span class="text-tertiary-fixed-dim font-label text-xs uppercase tracking-[0.3em] mb-6 block">Siamo qui per voi</span>
          <h1 class="font-headline text-5xl md:text-7xl text-primary leading-tight tracking-tight mb-6">
            Raccontateci <span class="italic">la vostra situazione</span>.
          </h1>
          <div class="h-1 w-24 bg-tertiary-fixed-dim"></div>
        </div>
        <div class="lg:col-span-4 pb-4">
          <p class="text-on-surface-variant text-lg leading-relaxed font-light">
            Ogni storia è diversa. Ascoltiamo con riservatezza e precisione, per capire insieme il percorso migliore. In presenza a Chieti o Roma, oppure a distanza su tutto il territorio nazionale.
          </p>
        </div>
      </div>
    </header>

    <!-- Form + Info -->
    <section class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
        <div class="reveal lg:col-span-7">
          <h2 class="font-headline text-3xl text-primary mb-3">Scriveteci un Messaggio</h2>
          <p class="text-on-surface-variant text-sm mb-10 leading-relaxed">Vi risponderemo entro un giorno lavorativo. Tutti i dati sono trattati con la massima riservatezza.</p>
          <form action="#" class="space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div>
                <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant mb-2" for="nome">Nome Completo</label>
                <input id="nome" class="w-full bg-transparent border-0 border-b border-outline/30 focus:ring-0 focus:border-primary transition-all duration-300 py-2 px-0 text-on-surface placeholder-on-surface-variant/40" placeholder="Mario Rossi" type="text" autocomplete="name" />
              </div>
              <div>
                <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant mb-2" for="email">Indirizzo Email</label>
                <input id="email" class="w-full bg-transparent border-0 border-b border-outline/30 focus:ring-0 focus:border-primary transition-all duration-300 py-2 px-0 text-on-surface placeholder-on-surface-variant/40" placeholder="mario@email.it" type="email" autocomplete="email" />
              </div>
            </div>
            <div>
              <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant mb-2" for="telefono">Telefono <span class="normal-case tracking-normal opacity-60">(opzionale)</span></label>
              <input id="telefono" class="w-full bg-transparent border-0 border-b border-outline/30 focus:ring-0 focus:border-primary transition-all duration-300 py-2 px-0 text-on-surface placeholder-on-surface-variant/40" placeholder="+39 333 000 0000" type="tel" autocomplete="tel" />
            </div>
            <div>
              <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant mb-2" for="oggetto">Oggetto della Consulenza</label>
              <input id="oggetto" class="w-full bg-transparent border-0 border-b border-outline/30 focus:ring-0 focus:border-primary transition-all duration-300 py-2 px-0 text-on-surface placeholder-on-surface-variant/40" placeholder="Licenziamento, Previdenza, Pubblico Impiego..." type="text" />
            </div>
            <div>
              <label class="block text-xs font-label uppercase tracking-widest text-on-surface-variant mb-2" for="messaggio">Messaggio</label>
              <textarea id="messaggio" class="w-full bg-transparent border-0 border-b border-outline/30 focus:ring-0 focus:border-primary transition-all duration-300 py-2 px-0 text-on-surface placeholder-on-surface-variant/40 resize-none" placeholder="Descrivete brevemente la vostra situazione. Ogni informazione resterà riservata." rows="4"></textarea>
            </div>
            <div class="flex items-start space-x-3 pt-2">
              <input class="rounded-none border-outline/30 text-primary focus:ring-primary mt-0.5 shrink-0" id="privacy" type="checkbox" />
              <label class="text-xs text-on-surface-variant leading-relaxed" for="privacy">
                Accetto la <a href={`${base}/privacy-policy`} class="underline decoration-tertiary-fixed-dim underline-offset-2">Privacy Policy</a> e il trattamento dei dati personali ai sensi del Regolamento UE 2016/679 (GDPR).
              </label>
            </div>
            <button class="group flex items-center justify-between w-full md:w-auto md:min-w-[260px] bg-primary text-on-primary px-8 py-5 hover:bg-primary/85 active:scale-[0.97] transition-all duration-200" type="submit">
              <span class="font-label uppercase tracking-widest text-sm">Invia Messaggio</span>
              <span class="material-symbols-outlined ml-4 group-hover:translate-x-1 transition-transform duration-200">arrow_right_alt</span>
            </button>
          </form>
        </div>
        <div class="reveal reveal-delay-1 lg:col-span-5 flex flex-col space-y-14">
          <div class="space-y-10">
            <div>
              <h3 class="font-label text-xs uppercase tracking-[0.25em] text-on-surface-variant mb-5">Sede di Chieti</h3>
              <div class="flex items-start space-x-5">
                <span class="material-symbols-outlined text-tertiary-fixed-dim text-3xl shrink-0">location_on</span>
                <div>
                  <p class="font-serif text-2xl text-primary leading-tight mb-2">Corso Marrucino<br />Chieti (CH)</p>
                  <a href="tel:+390871000000" class="text-on-surface-variant hover:text-primary transition-colors duration-200 text-lg">0871 000000</a>
                </div>
              </div>
            </div>
            <div>
              <h3 class="font-label text-xs uppercase tracking-[0.25em] text-on-surface-variant mb-5">Sede di Roma</h3>
              <div class="flex items-start space-x-5">
                <span class="material-symbols-outlined text-tertiary-fixed-dim text-3xl shrink-0">location_on</span>
                <div>
                  <p class="font-serif text-2xl text-primary leading-tight mb-2">Via del Corso<br />Roma (RM)</p>
                  <a href="tel:+3906000000" class="text-on-surface-variant hover:text-primary transition-colors duration-200 text-lg">06 000000</a>
                </div>
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-2">
              <div>
                <h3 class="font-label text-xs uppercase tracking-[0.25em] text-on-surface-variant mb-3">Email</h3>
                <a href="mailto:info@avvocatopagliaro.it" class="text-on-surface text-base hover:text-primary transition-colors duration-200">info@avvocatopagliaro.it</a>
              </div>
              <div>
                <h3 class="font-label text-xs uppercase tracking-[0.25em] text-on-surface-variant mb-3">Orari</h3>
                <p class="text-on-surface text-base mb-1">Lunedì — Venerdì</p>
                <p class="text-on-surface text-base font-medium">09:00 — 18:30</p>
              </div>
            </div>
          </div>
          <div class="bg-surface-container-low p-8 border-l-4 border-tertiary-fixed-dim">
            <h3 class="font-headline text-xl text-primary mb-5">Come possiamo incontrarci</h3>
            <ul class="space-y-4 text-on-surface-variant text-sm">
              <li class="flex items-center gap-3">
                <span class="material-symbols-outlined text-tertiary-fixed-dim text-xl shrink-0">location_on</span>
                In presenza a Chieti o Roma, su appuntamento
              </li>
              <li class="flex items-center gap-3">
                <span class="material-symbols-outlined text-tertiary-fixed-dim text-xl shrink-0">call</span>
                Consulenza telefonica, nei tempi del cliente
              </li>
              <li class="flex items-center gap-3">
                <span class="material-symbols-outlined text-tertiary-fixed-dim text-xl shrink-0">videocam</span>
                Videochiamata — Teams, Zoom o WhatsApp
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Sedi — Immagini -->
    <section class="max-w-7xl mx-auto px-8 mt-20">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2 h-72">
        <div class="relative overflow-hidden group cursor-default">
          <img
            src="https://images.unsplash.com/photo-1529260830199-42c24126f198?w=900&auto=format&fit=crop&q=80"
            alt="Chieti — Sede dello Studio Legale Pagliaro"
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 scale-105 group-hover:scale-100"
          />
          <div class="absolute inset-0 bg-primary/55 flex items-end p-8">
            <div>
              <p class="text-tertiary-fixed-dim text-xs font-label uppercase tracking-[0.25em] mb-1">Sede principale</p>
              <p class="text-white font-headline text-4xl italic">Chieti</p>
              <p class="text-white/60 font-label text-sm mt-1 uppercase tracking-widest">Corso Marrucino</p>
            </div>
          </div>
        </div>
        <div class="relative overflow-hidden group cursor-default">
          <img
            src="https://images.unsplash.com/photo-1552832230-c0197dd311b5?w=900&auto=format&fit=crop&q=80"
            alt="Roma — Sede dello Studio Legale Pagliaro"
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 scale-105 group-hover:scale-100"
          />
          <div class="absolute inset-0 bg-primary/55 flex items-end p-8">
            <div>
              <p class="text-tertiary-fixed-dim text-xs font-label uppercase tracking-[0.25em] mb-1">Sede di Roma</p>
              <p class="text-white font-headline text-4xl italic">Roma</p>
              <p class="text-white/60 font-label text-sm mt-1 uppercase tracking-widest">Via del Corso</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mappe Google -->
    <section class="max-w-7xl mx-auto px-8 mt-2">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        <div class="relative overflow-hidden h-80 bg-surface-container-highest">
          <iframe
            class="map-frame absolute inset-0 w-full h-full border-0"
            src="https://maps.google.com/maps?q=Corso+Marrucino+Chieti+CH+Italia&output=embed&hl=it&z=15"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Sede di Chieti — Studio Legale Pagliaro, Corso Marrucino"
          ></iframe>
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-primary/70 to-transparent h-16 pointer-events-none"></div>
          <div class="absolute bottom-4 left-4 pointer-events-none">
            <span class="text-white/80 font-label text-xs uppercase tracking-widest">Chieti — Corso Marrucino</span>
          </div>
        </div>
        <div class="relative overflow-hidden h-80 bg-surface-container-highest">
          <iframe
            class="map-frame absolute inset-0 w-full h-full border-0"
            src="https://maps.google.com/maps?q=Via+del+Corso+Roma+RM+Italia&output=embed&hl=it&z=15"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Sede di Roma — Studio Legale Pagliaro, Via del Corso"
          ></iframe>
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-primary/70 to-transparent h-16 pointer-events-none"></div>
          <div class="absolute bottom-4 left-4 pointer-events-none">
            <span class="text-white/80 font-label text-xs uppercase tracking-widest">Roma — Via del Corso</span>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>
