---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.avvocatopagliaro.it/' },
    { '@type': 'ListItem', position: 2, name: 'Competenze', item: 'https://www.avvocatopagliaro.it/competenze' },
  ],
});
---

<Layout
  title="Competenze | Studio Legale Pagliaro — Diritto del Lavoro"
  description="Aree di competenza dello Studio Legale Pagliaro: diritto del lavoro, previdenza sociale, pubblico impiego, diritto sindacale e infortunistica."
  canonical="https://www.avvocatopagliaro.it/competenze"
  currentPage="competenze"
  jsonLd={jsonLd}
>
  <main class="pt-32">
    <!-- Hero -->
    <section class="max-w-7xl mx-auto px-8 mb-28">
      <PageHero
        eyebrow="Il Nostro Rigore"
        rule={true}
        description="Un approccio dedicato e specializzato alla tutela dei lavoratori. Ogni pratica è trattata con precisione giuridica e attenzione alla persona."
      >
        Aree di <br /><span class="italic">Competenza</span>
      </PageHero>
    </section>

    <!-- Bento Grid -->
    <section class="max-w-7xl mx-auto px-8 mb-40">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="md:col-span-2 group relative overflow-hidden bg-primary p-12 flex flex-col justify-between min-h-[500px]">
          <div class="relative z-10">
            <h3 class="font-headline text-4xl text-on-primary mb-4">Diritto del Lavoro</h3>
            <p class="text-on-primary/70 text-lg max-w-md leading-relaxed">
              Tutela completa nei rapporti di lavoro privato: licenziamenti illegittimi, demansionamento, mobbing, discriminazioni, trasferimenti, variazioni contrattuali e risarcimento danni.
            </p>
          </div>
          <div class="relative z-10 flex items-center group/link">
            <a class="text-on-primary font-label text-sm uppercase tracking-widest border-b border-tertiary-fixed-dim/30 pb-1 group-hover/link:border-tertiary-fixed-dim transition-all" href={`${base}/contatti`}>Prenota una Consulenza</a>
          </div>
        </div>
        <div class="group bg-surface-container-low p-10 flex flex-col justify-between transition-colors hover:bg-surface-container">
          <div>
            <h3 class="font-headline text-3xl text-primary mb-4">Previdenza Sociale</h3>
            <p class="text-on-surface-variant leading-relaxed mb-6">
              Ricorsi INPS, pensioni di anzianità e anticipate, invalidità civile, contributi previdenziali e vertenze previdenziali in ogni grado di giudizio.
            </p>
          </div>
          <ul class="space-y-3 text-sm font-label text-on-surface/80">
            <li class="flex items-center gap-2"><span class="w-1 h-1 bg-tertiary-fixed-dim rounded-full"></span> Pensioni e Contributi</li>
            <li class="flex items-center gap-2"><span class="w-1 h-1 bg-tertiary-fixed-dim rounded-full"></span> Invalidità Civile e Lavoro</li>
            <li class="flex items-center gap-2"><span class="w-1 h-1 bg-tertiary-fixed-dim rounded-full"></span> Ricorsi INPS e INAIL</li>
          </ul>
        </div>
        <div class="group bg-surface-container-highest p-10 flex flex-col justify-between">
          <div>
            <h3 class="font-headline text-2xl text-primary mb-3">Pubblico Impiego</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">
              Controversie con enti pubblici, concorsi e selezioni, progressioni economiche e di carriera, procedimenti disciplinari e mobbing nel lavoro pubblico.
            </p>
          </div>
          <a class="inline-block mt-8 text-primary font-label text-xs uppercase tracking-widest underline decoration-tertiary-fixed-dim underline-offset-4" href={`${base}/contatti`}>Consulenza</a>
        </div>
        <div class="group bg-primary-container p-10 flex flex-col justify-between">
          <div>
            <h3 class="font-headline text-2xl text-on-primary mb-3">Diritto Sindacale</h3>
            <p class="text-on-primary/60 text-sm leading-relaxed">
              Assistenza nelle vertenze sindacali collettive, contrattazione, tutela delle rappresentanze sindacali e conflitti collettivi di lavoro.
            </p>
          </div>
          <a class="inline-block mt-8 text-on-primary font-label text-xs uppercase tracking-widest underline decoration-tertiary-fixed-dim underline-offset-4" href={`${base}/contatti`}>Consulenza</a>
        </div>
        <div class="group bg-white p-10 flex flex-col justify-between shadow-sm border border-outline-variant/10">
          <div>
            <h3 class="font-headline text-2xl text-primary mb-3">Infortunistica</h3>
            <p class="text-on-surface-variant text-sm leading-relaxed">
              Risarcimento danni per infortuni sul lavoro, malattie professionali, responsabilità del datore di lavoro e tutela dell&rsquo;integrità fisica del lavoratore.
            </p>
          </div>
          <a class="inline-block mt-8 text-primary font-label text-xs uppercase tracking-widest underline decoration-tertiary-fixed-dim underline-offset-4" href={`${base}/contatti`}>Consulenza</a>
        </div>
      </div>
    </section>

    <!-- Il Metodo -->
    <section class="bg-primary py-32 text-on-primary overflow-hidden">
      <div class="max-w-7xl mx-auto px-8">
        <div class="mb-20 max-w-2xl">
          <span class="text-tertiary-fixed-dim font-label text-sm uppercase tracking-[0.3em] mb-6 block">Il Nostro Approccio</span>
          <h2 class="font-serif text-5xl text-on-primary mb-6 leading-tight">Il Metodo</h2>
          <div class="h-1 w-24 bg-tertiary-fixed-dim mb-8"></div>
          <p class="text-on-primary-container font-light">
            Ogni vertenza segue tre fasi: ascolto, strategia, difesa. Il cliente è informato a ogni passaggio.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16 relative">
          <div class="relative group">
            <span class="text-8xl font-headline italic text-tertiary-fixed-dim/10 absolute -top-12 -left-4">01</span>
            <div class="relative pt-8">
              <h4 class="font-headline font-extrabold text-2xl mb-4 text-on-primary">Ascolto e Analisi</h4>
              <p class="text-on-primary/70 leading-relaxed font-light">
                Prima di tutto, ascoltiamo. Ogni caso viene analizzato nella sua specificità, raccogliendo tutta la documentazione utile e identificando i margini di azione.
              </p>
            </div>
          </div>
          <div class="relative group">
            <span class="text-8xl font-headline italic text-tertiary-fixed-dim/10 absolute -top-12 -left-4">02</span>
            <div class="relative pt-8">
              <h4 class="font-headline font-extrabold text-2xl mb-4 text-on-primary">Strategia Personalizzata</h4>
              <p class="text-on-primary/70 leading-relaxed font-light">
                Definiamo insieme il percorso più efficace: accordo stragiudiziale, mediazione o azione giudiziale. Il cliente è sempre informato e coinvolto.
              </p>
            </div>
          </div>
          <div class="relative group">
            <span class="text-8xl font-headline italic text-tertiary-fixed-dim/10 absolute -top-12 -left-4">03</span>
            <div class="relative pt-8">
              <h4 class="font-headline font-extrabold text-2xl mb-4 text-on-primary">Difesa Rigorosa</h4>
              <p class="text-on-primary/70 leading-relaxed font-light">
                Rappresentanza ferma e competente in ogni grado di giudizio, con aggiornamento costante del cliente sull&rsquo;avanzamento della pratica.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <CTASection
      title="Vuoi capire se hai un caso?"
      description="Prenotate una prima consultazione per discutere la vostra situazione con l&rsquo;Avv. Pagliaro."
      primaryHref={`${base}/contatti`}
      primaryLabel="Contatta lo Studio"
      secondaryHref={`${base}/profilo`}
      secondaryLabel="Chi Siamo"
    />
  </main>
</Layout>
